# TheFabric — Environment variables
# Copy this file to .env and fill in the values you need.
# Only KFABRIC_URL and PYSPUR_URL are required for live integrations.
# All other integrations work offline by default.

# ── KFabric ───────────────────────────────────────────────────────────────────
# Base URL of a running KFabric instance (fbailleux2/kfabric).
# If not set, TheFabric generates the query plan but does not submit it.
KFABRIC_URL=http://localhost:8000

# KFabric API key (Bearer token), if your KFabric instance requires auth.
KFABRIC_API_KEY=

# ── PySpur ────────────────────────────────────────────────────────────────────
# Base URL of a running PySpur instance (https://github.com/PySpur-Dev/pyspur).
# If not set, TheFabric generates the workflow JSON but does not submit it.
PYSPUR_URL=http://localhost:6080

# LLM model to use inside PySpur nodes.
# Format: provider/model-name as used by PySpur's LLM registry.
# Examples:
#   openai/chatgpt-4o-latest        (default)
#   anthropic/claude-sonnet-4-6
#   ollama/mistral
PYSPUR_MODEL=openai/chatgpt-4o-latest

# ── BundleFabric ──────────────────────────────────────────────────────────────
# Path to the BundleFabric bundles directory (fbailleux2/bundlefabric/bundles).
# Default: ../bundlefabric/bundles relative to the thefabric repo root.
# Override if you cloned bundlefabric to a different location.
# BUNDLEFABRIC_DIR=/path/to/bundlefabric/bundles

# ── Hermes Agent ──────────────────────────────────────────────────────────────
# Hermes has no REST API — TheFabric writes MEMORY.md, USER.md and SKILL.md files
# to the output/hermes/ directory. Point Hermes to that directory to pick them up.
# No env var needed; output path is controlled by --output CLI flag.
